# 1-я матрица предварительных расчетных объемов НП для первой очереди
estimated_i_j_k_l_s.First(1 from n) = assign_matrix(estimated_i_j_k_l_s_not_exceed.First, estimated_i_j_k_l_s_exceed.First)
    where
        estimated_i_j_k_l_s.First(1)(i, j, s, k, l)         of number
        estimated_i_j_k_l_s_exceed.First(i, j, s, k, l)     of number
        estimated_i_j_k_l_s_not_exceed.First(i, j, s, k, l) of number
        estimated_i_j_k_l_s.First(1)         of matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        estimated_i_j_k_l_s_exceed.First     of matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        estimated_i_j_k_l_s_not_exceed.First of matrix(Product, Refinery, Ship_terms, Region, Market_participant)
            where
