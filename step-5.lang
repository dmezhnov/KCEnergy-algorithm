                l  of P  from index # Индексы субъекта рынка

# Предварительный объем НП, где итоговый суммарный объём Запросов очереди queue на НПЗ не превышает доступный объём
estimated_i_j_k_l_s_not_exceed(queue) = requests_i_j_k_l_s_corrected_not_exceed(queue);
    where
        estimated_i_j_k_l_s_not_exceed(queue)(i, j, s, k, l)          of number
        requests_i_j_k_l_s_corrected_not_exceed(queue)(i, j, s, k, l) of number
        estimated_i_j_k_l_s_not_exceed(queue)          of matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        requests_i_j_k_l_s_corrected_not_exceed(queue) of matrix(Product, Refinery, Ship_terms, Region, Market_participant)
            where
