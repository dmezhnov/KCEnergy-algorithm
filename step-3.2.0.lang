    where
        requests_i_j_k_l_first(i, k, l, j):                    number
        requests_i_j_k_l_first_deficit_single(i, k, l, j):     number
        refinery_count_by_deficit_requests_single(i*, k*, l*): number
        requests_i_j_k_l_first:                    matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_single:     matrix(Product, Region, Market_participant, Refinery)
        refinery_count_by_deficit_requests_single: matrix(Product, Region, Market_participant)
        contains: condition
            where
                i = i*
                k = k*
                l = l*
                    where
                        Product, Region, Market_participant, Refinery: axis # Оси заявок
                        i, i*: index # Индексы нефпродукта
                        k, k*: index # Индексы региона
                        l, l*: index # Индексы субъекта рынка
                        j:     index # Индексы НПЗ

requests_i_j_k_l_first_deficit_single = filter_by_pair(requests_i_j_k_l_first, contains, refinery_count_by_deficit_requests_single)
