#### Определяем количество НПЗ в запросах субъекта рынка (которые являются владельцами АЗС / которые обслуживаются в 1-ю очередь)
# Выделяем Запросы Владельцев АЗС и далее ветвимся:
# — если Запросы на один дефицитный НПЗ, применяем ограничение по скользящему среднему (3.2.1);
# — иначе работаем с суммой по НПЗ и долями (3.2.2).

# Матрица дифицитных запросов (запросы на дифицитный НПЗ) первой очереди
requests_i_j_k_l_s_first_deficit(i) = (
    (i, j) = (
        (i, j, s) = (
            (i, j, s, k) = (
                (i, j, s, k, l) = requests_i_j_k_l_s_first(i, j, s, k, l)
            )
        )
    )
)
    where
        requests_i_j_k_l_s_first(i, j, s, k, l):         number # Запрашиваемый объем НП
        requests_i_j_k_l_s_first_deficit(i, j, s, k, l): number
        requests_i_j_deficit(i*, j*):                    number
        requests_i_j_k_l_s_first:         matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        requests_i_j_k_l_s_first_deficit: matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        requests_i_j_deficit:             matrix(Product, Refinery)
            where
                i = i*
                j = j*
                    where
                        contains: condition
                        Product, Refinery, Ship_terms, Region, Market_participant: axis # Оси заявок
                        i, i*: index # Индексы нефпродукта
                        j, j*: index # Индексы НПЗ
                        s, s*: index # Индексы условий поставки
                        k:     index # Индексы региона
                        l:     index # Индексы субъекта рынка

requests_i_j_k_l_s_first_deficit = filter_by_pair(requests_i_j_k_l_s_first, contains, requests_i_j_deficit)
    where
        requests_i_j_k_l_s_first(i, j, s, k, l):         number # Запрашиваемый объем НП
        requests_i_j_k_l_s_first_deficit(i, j, s, k, l): number
        requests_i_j_deficit(i, j):                      number
        requests_i_j_k_l_s_first:         matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        requests_i_j_k_l_s_first_deficit: matrix(Product, Refinery, Ship_terms, Region, Market_participant)
        requests_i_j_deficit:             matrix(Product, Refinery)
        contains: condition
            where
                Product, Refinery, Ship_terms, Region, Market_participant: axis # Оси заявок
                i: index # Индексы нефпродукта
                j: index # Индексы НПЗ
                s: index # Индексы условий поставки
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                J: index # Количество НПЗ

# Матрица количества НПЗ в дифицитных запросах (запросы на дифицитный НПЗ) первой очереди
refinery_count_by_deficit_requests(i) = (
    (i, k) = (
        (i, k, l) = (
            (i, k, l, s) = J
        )
    )
)
    where
        refinery_count_by_deficit_requests(i, k, l, s):  number
        requests_i_j_k_l_s_first_deficit(i, k, l, s, j): number
        requests_i_j_k_l_s_first_deficit:   matrix(Product, Region, Market_participant, Ship_terms, Refinery)
        refinery_count_by_deficit_requests: matrix(Product, Region, Market_participant, Ship_terms)
        requests_i_j_k_l_s_first_deficit(i, k, l, s, 1), ..., requests_i_j_k_l_s_first_deficit(i, k, l, s, J) => requests_i_j_k_l_s_first_deficit(j)
            where
                Product, Region, Market_participant, Ship_terms, Refinery: axis # Оси заявок
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                s: index # Индексы условия поставки
                j: index # Индексы НПЗ
                J: index # Количество НПЗ

refinery_count_by_deficit_requests = count_coordinates_by_axis(requests_i_j_k_l_s_first_deficit, Refinery)
    where
        refinery_count_by_deficit_requests(i, k, l, s):  number
        requests_i_j_k_l_s_first_deficit(i, k, l, s, j): number
        requests_i_j_k_l_s_first_deficit:   matrix(Product, Region, Market_participant, Ship_terms, Refinery)
        refinery_count_by_deficit_requests: matrix(Product, Region, Market_participant, Ship_terms)
        requests_i_j_k_l_s_first_deficit(i, k, l, s, 1), ..., requests_i_j_k_l_s_first_deficit(i, k, l, s, J) => requests_i_j_k_l_s_first_deficit(j)
            where
                Product, Region, Market_participant, Ship_terms, Refinery: axis # Оси заявок
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                s: index # Индексы условия поставки
                j: index # Индексы НПЗ
                J: index # Количество НПЗ

