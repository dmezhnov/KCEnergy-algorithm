    )
)
    where
        refinery_count_by_deficit_requests_single(i, k, l, s): number = J
        refinery_count_by_deficit_requests(i, k, l, s):        number = J
        refinery_count_by_deficit_requests_single: matrix(Product, Region, Market_participant, Ship_terms)
        refinery_count_by_deficit_requests:        matrix(Product, Region, Market_participant, Ship_terms)
            where
