    where
        requests_i_j_k_l_s.First(i, k, l, s, j)                 of number
        requests_i_j_k_l_s_deficit_multiple(i, k, l, s, j)      of number
        refinery_count_by_deficit_requests_multiple(i, k, l, s) of number
        requests_i_j_k_l_s.First                    of matrix(Product, Region, Market_participant, Ship_terms, Refinery)
        requests_i_j_k_l_s_deficit_multiple         of matrix(Product, Region, Market_participant, Ship_terms, Refinery)
        refinery_count_by_deficit_requests_multiple of matrix(Product, Region, Market_participant, Ship_terms)
        contains from condition
            where
                Product, Region, Market_participant, Ship_terms, Refinery from axis # Оси заявок
                i  for I  from index # Индексы нефпродукта
                k  for K  from index # Индексы региона
                l  for P  from index # Индексы субъекта рынка
                s  for C  from index # Индексы условия поставки
                j  for J  from index # Индексы НПЗ

requests_i_j_k_l_s_deficit_multiple = filter_by_pair(requests_i_j_k_l_s.First, contains, refinery_count_by_deficit_requests_multiple)
    where
        requests_i_j_k_l_s.First(i, k, l, s, j)                 of number
        requests_i_j_k_l_s_deficit_multiple(i, k, l, s, j)      of number
        refinery_count_by_deficit_requests_multiple(i, k, l, s) of number
        requests_i_j_k_l_s.First                    of matrix(Product, Region, Market_participant, Ship_terms, Refinery)
        requests_i_j_k_l_s_deficit_multiple         of matrix(Product, Region, Market_participant, Ship_terms, Refinery)
        refinery_count_by_deficit_requests_multiple of matrix(Product, Region, Market_participant, Ship_terms)
        contains from condition
