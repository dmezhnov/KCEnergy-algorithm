requests_adjusted(1) =   requests_value_share(1) * moving_average(1)
                            when threshold_by_refinery(1) < requests_by_market_participant_region(1)
requests_adjusted(1) =   requsets_value(1)
                            when threshold_by_refinery(1) >= requests_by_market_participant_region(1)
...

requests_adjusted(m) =   requests_value_share(m) * moving_average(m)
                            when threshold_by_refinery(m) < requests_by_market_participant_region(m)
requests_adjusted(m) =   requsets_value(m)
                            when threshold_by_refinery(m) >= requests_by_market_participant_region(m)


######################################################################################################################

shortfall_volume(1) = requsets_value(1) - requests_adjusted(1)
            when threshold_by_refinery(1) < requests_by_market_participant_region(1)
shortfall_volume(1) = 0
            when threshold_by_refinery(1) >= requests_by_market_participant_region(1)
...

shortfall_volume(m) = requsets_value(m) - requests_adjusted(m)
            when threshold_by_refinery(m) < requests_by_market_participant_region(m)
shortfall_volume(m) = 0
            when threshold_by_refinery(m) >= requests_by_market_participant_region(m)

shortfall_volume_sum: number = shortfall_volume(1) + ... + shortfall_volume(m)

