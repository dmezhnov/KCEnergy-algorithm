number:                                  core
operation:                               matrix_types.lang
sum_by_axes, for_each_pair:              matrix_operation.lang
requests_i_j_k_l_first_deficit_multiple: step-3.2.0.lang
moving_average:                          step-3.1.0.lang

# Матрица множественных (запросы на несколько НПЗ) дифицитных запросов (запросы на дифицитный НПЗ) первой очереди
requests_i_k_l_first_deficit_multiple(i) = (
    (i, k) = (
        (i, k, l) = requests_i_j_k_l_first_deficit_multiple(i, k, l, 1) + ... + requests_i_j_k_l_first_deficit_multiple(i, k, l, J)
    )
)
    where
        requests_i_j_k_l_first_deficit_multiple(i, k, l, j): number
        requests_i_k_l_first_deficit_multiple(i, k, l):      number
        requests_i_j_k_l_first_deficit_multiple: matrix(Product, Region, Market_participant, Refinery)
        requests_i_k_l_first_deficit_multiple:   matrix(Product, Region, Market_participant)
            where
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ
                J: index # Количество НПЗ

requests_i_k_l_first_deficit_multiple = sum_by_axes(requests_i_j_k_l_first_deficit_multiple, Refinery)
    where
        requests_i_j_k_l_first_deficit_multiple(i, k, l, j): number
        requests_i_k_l_first_deficit_multiple(i, k, l):      number
        requests_i_j_k_l_first_deficit_multiple: matrix(Product, Region, Market_participant, Refinery)
        requests_i_k_l_first_deficit_multiple:   matrix(Product, Region, Market_participant)
            where
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

# Матрица долей множественных (запросы на несколько НПЗ) дифицитных запросов (запросы на дифицитный НПЗ) первой очереди
requests_i_j_k_l_first_deficit_multiple_share(i) = (
    (i, k) = (
        (i, k, l) = (
            (i, k, l , j) = requests_i_j_k_l_first_deficit_multiple(i, k, l, j) / requests_i_k_l_first_deficit_multiple(i, k, l)
        )
    )
)
    where
        requests_i_j_k_l_first_deficit_multiple_share(i, k, l, j): number
        requests_i_j_k_l_first_deficit_multiple(i, k, l, j):       number
        requests_i_k_l_first_deficit_multiple(i, k, l):            number
        requests_i_j_k_l_first_deficit_multiple_share: matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple:       matrix(Product, Region, Market_participant, Refinery)
        requests_i_k_l_first_deficit_multiple:         matrix(Product, Region, Market_participant)
            where
                /: operation
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

requests_i_j_k_l_first_deficit_multiple_share = for_each_pair(requests_i_j_k_l_first_deficit_multiple, divide, requests_i_k_l_first_deficit_multiple)
    where
        requests_i_j_k_l_first_deficit_multiple_share(i, k, l, j): number
        requests_i_j_k_l_first_deficit_multiple(i, k, l, j):       number
        requests_i_k_l_first_deficit_multiple(i, k, l):            number
        requests_i_j_k_l_first_deficit_multiple_share:  matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple:        matrix(Product, Region, Market_participant, Refinery)
        requests_i_k_l_first_deficit_multiple:          matrix(Product, Region, Market_participant)
            where
                divide: operation
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

requests_i_j_k_l_first_deficit_multiple_distributed_aux(i) = (
    (i, k) = (
        (i, k, l) = (
            (i, k, l, j) = requests_i_j_k_l_first_deficit_multiple_share(i, k, l, j) * moving_average(i, k, l)
        )
    )
)
    where
        requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j): number
        requests_i_j_k_l_first_deficit_multiple_share(i, k, l, j):       number
        moving_average(i, k, l):                                         number # Скользящее среднее
        requests_i_j_k_l_first_deficit_multiple_distributed_aux: matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple_share:       matrix(Product, Region, Market_participant, Refinery)
        moving_average:                                      matrix(Product, Region, Market_participant)  # Скользящее среднее
            where
                *: operation
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

requests_i_j_k_l_first_deficit_multiple_distributed_aux = for_each_pair(requests_i_j_k_l_first_deficit_multiple_share, multiply, moving_average)
    where
        requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j): number
        requests_i_j_k_l_first_deficit_multiple_share(i, k, l, j):       number
        moving_average(i, k, l):                                         number # Скользящее среднее
        requests_i_j_k_l_first_deficit_multiple_distributed_aux: matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple_share:       matrix(Product, Region, Market_participant, Refinery)
        moving_average:                                      matrix(Product, Region, Market_participant)  # Скользящее среднее
            where
                multiply: operation
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

# Матрица выпадающих при корректировке на проливы объемы множественных (запросы на несколько НПЗ) дифицитных запросов (запросы на дифицитный НПЗ) первой очереди
requests_i_j_k_l_first_deficit_multiple_distributed(i) = (
    (i, k) = (
        (i, k, l) = (
            (i, k, l, j) = requests_i_j_k_l_first_deficit_multiple(i, k, l, j) - requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j)
        )
    )
)
    where
        requests_i_j_k_l_first_deficit_multiple_distributed(i, k, l, j):            number
        requests_i_j_k_l_first_deficit_multiple(i, k, l, j):             number
        requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j): number
        requests_i_j_k_l_first_deficit_multiple_distributed:            matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple:             matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple_distributed_aux: matrix(Product, Region, Market_participant, Refinery)
            where
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

requests_i_j_k_l_first_deficit_multiple_distributed = for_each_pair(requests_i_j_k_l_first_deficit_multiple, subtract, requests_i_j_k_l_first_deficit_multiple_distributed_aux)
    where
        requests_i_j_k_l_first_deficit_multiple_distributed(i, k, l, j):            number
        requests_i_j_k_l_first_deficit_multiple(i, k, l, j):             number
        requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j): number
        requests_i_j_k_l_first_deficit_multiple_distributed:            matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple:             matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple_distributed_aux: matrix(Product, Region, Market_participant, Refinery)
            where
                subtract: operation
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ

# Матрица скорректированных на проливы объемы множественных (запросы на несколько НПЗ) дифицитных запросах (запросы на дифицитный НПЗ) первой очереди
requests_i_j_k_l_first_deficit_multiple_reduced(i) = (
    (i, k) = (
        (i, k, l) = (
            (i, k, l, j) = requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j)
        )
    )
)
    where
        requests_i_j_k_l_first_deficit_multiple_reduced(i, k, l, j):     number
        requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j): number = requsest_value
        moving_average(i, k, l):                                         number = average_value # Скользящее среднее
        requests_i_j_k_l_first_deficit_multiple_reduced:     matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple_distributed_aux: matrix(Product, Region, Market_participant, Refinery)
        moving_average:                                      matrix(Product, Region, Market_participant)  # Скользящее среднее
            where
                requsest_value > average_value
                    where
                        >: condition
                        Product, Region, Market_participant, Refinery: axis
                        i: index # Индексы нефпродукта
                        k: index # Индексы региона
                        l: index # Индексы субъекта рынка
                        j: index # Индексы НПЗ

requests_i_j_k_l_first_deficit_multiple_reduced = for_each_pair(requests_i_j_k_l_first_deficit_multiple_distributed_aux, min, moving_average)
    where
        requests_i_j_k_l_first_deficit_multiple_reduced(i, k, l, j):     number
        requests_i_j_k_l_first_deficit_multiple_distributed_aux(i, k, l, j): number
        moving_average(i, k, l):                                         number # Скользящее среднее
        requests_i_j_k_l_first_deficit_multiple_reduced:     matrix(Product, Region, Market_participant, Refinery)
        requests_i_j_k_l_first_deficit_multiple_distributed_aux: matrix(Product, Region, Market_participant, Refinery)
        moving_average:                                      matrix(Product, Region, Market_participant)  # Скользящее среднее
            where
                min: operation
                Product, Region, Market_participant, Refinery: axis
                i: index # Индексы нефпродукта
                k: index # Индексы региона
                l: index # Индексы субъекта рынка
                j: index # Индексы НПЗ
