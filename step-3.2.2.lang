requests_value_share = requests_value_share(1), ..., requests_value_share(N): number

###########################

(1) = (
    (1) = (
        requests_value_share(1) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
        ...
        requests_value_share(L) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
    )

    ...


    (Q) = (
        requests_value_share(1) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
        ...
        requests_value_share(L) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
    )
)

...

(N) = (
    (1) = (
        requests_value_share(1) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
        ...
        requests_value_share(L) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
    )

    ...


    (Q) = (
        requests_value_share(1) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
        ...
        requests_value_share(L) = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
    )
)
###########################

requests_value_share(1): number = (requsets_value(1) / requsets_value_sum) * moving_average(1) = request_by_share_percentage(1) * moving_average(1)
...
requests_value_share(N): number = (requsets_value(N) / requsets_value_sum) * moving_average(N) = request_by_share_percentage(N) * moving_average(N)
    where
        requsets_value(1), ..., requsets_value(N): requests_by_gas_station_owner
        requsets_value_sum: requests_by_refinery
        (requsets_value(1) / requsets_value_sum), ..., (requsets_value(N) / requsets_value_sum): request_by_share_percentage
        moving_average(1), ..., moving_average(N): moving_average
            where
                requests_by_gas_station_owner: matrix(Product, Refinery, Region, Market_participant)
                requests_by_refinery: matrix(Product, Region, Market_participant)
                request_by_share_percentage: matrix(Product, Refinery, Region, Market_participant)
                moving_average: matrix(Region, Product, Market_participant)

###########################

requests_value_share(i): number = (requsets_value(i) / requsets_value_sum) * moving_average(i)
    where
        requsets_value_sum: requests_by_refinery
        moving_average(i): moving_average AND matrix(Region, Product)
            where
                requests_by_refinery: matrix(Product, Region, Market_participant)
                moving_average: matrix(Region, Product, Market_participant)

