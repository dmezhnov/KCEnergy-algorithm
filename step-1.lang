### Вычисляем суммарные запрашиваемые объемы по всем НПЗ и регионам поставки
# Отбираем Запросы на покупку НП на рассматриваемый период по виду НП,
# НПЗ и региону поставки и рассчитываем суммарные объёмы по всем Субъектам рынка.
# Результат — матрица суммарных объёмов по (Product, Refinery) для последующей
# проверки на дефицит/профицит.

# Заявки субъектов рынка за рассматриваемый период обслуживаемые в первую очередь
requests_i_j_k_l_s_first(i) = (
    (i, j) = (
        (i, j, k) = (
            (i, j, k, l) = (
                (i, j, k, l, s) = requests_i_j_k_l_s_l0(i, j, k, l, l0, s)
            )
        )
    )
)
    where
        requests_i_j_k_l_s_l0(i, j, k, l, l0, s) of  number # Запрашиваемый объем НП
        requests_i_j_k_l_s_first(i, j, k, l, s)  of  number
        requests_i_j_k_l_s_l0    of matrix(Product, Refinery, Region, Market_participant, Queue, Ship_terms)
        requests_i_j_k_l_s_first of matrix(Product, Refinery, Region, Market_participant, Ship_terms)
            where
