        requests_i_j_k_l    of matrix(Product, Refinery, Region, Market_participant)
        requests_i_j_k_l(i) of matrix(         Refinery, Region, Market_participant)
        requests_i_j_k_l_l0(i, j, k, l, 1), ..., requests_i_j_k_l_l0(i, j, k, l, L0) => requests_i_j_k_l_l0(l0)
            where
                Product, Refinery, Region, Market_participant, Queue from axis # Оси заявок
                i  of I  from index  # Индексы нефпродукта
                j  of J  from index  # Индексы НПЗ
                k  of k  from index  # Индексы региона
                l  of P  from index  # Индексы субъекта рынка
                l0 of R  from index  # Индексы очереди
                L0       from index  # Количество очередей

requests_i_j_k_l = sum_by_axes(requests_i_j_k_l_l0, Queue)
    where
        requests_i_j_k_l_l0(i, j, k, l, l0) of  number # Запрашиваемый объем НП
        requests_i_j_k_l(i, j, k, l)        of  number
        requests_i_j_k_l_l0 of matrix(Product, Refinery, Region, Market_participant, Queue)
        requests_i_j_k_l    of matrix(Product, Refinery, Region, Market_participant)
        requests_i_j_k_l(i) of matrix(         Refinery, Region, Market_participant)
        requests_i_j_k_l_l0(i, j, k, l, 1), ..., requests_i_j_k_l_l0(i, j, k, l, L0) => requests_i_j_k_l_l0(l0)
            where
                Product, Refinery, Region, Market_participant, Queue from axis # Оси заявок
                i  of I  from index  # Индексы нефпродукта
                j  of J  from index  # Индексы НПЗ
                k  of k  from index  # Индексы региона
                l  of P  from index  # Индексы субъекта рынка
                l0 of R  from index  # Индексы очереди
                L0       from index  # Количество очередей

requests_i_j_k(i) = (
    (i, j) = (
        (i, j, k) = requests_i_j_k_l(i, j, k, 1) + ... + requests_i_j_k_l(i, j, k, L)
    )
)
    where
        requests_i_j_k_l(i, j, k, l) of  number # Запрашиваемый объем НП
        requests_i_j_k(i, j, k)      of  number
        requests_i_j_k_l  of matrix(Product, Refinery, Region, Market_participant)
        requests_i_j_k    of matrix(Product, Refinery, Region)
        requests_i_j_k(i) of matrix(         Refinery, Region)
        requests_i_j_k_l(i, j, k, 1), ..., requests_i_j_k_l(i, j, k, L) => requests_i_j_k_l(l)
            where
                Product, Refinery, Region, Market_participant from axis # Оси заявок
                i  of I  from index # Индексы нефпродукта
                j  of J  from index # Индексы НПЗ
                k  of K  from index # Индексы региона
                l  of P  from index # Индексы субъекта рынка
                L        from index # Количество субъектов рынка

requests_i_j_k = sum_by_axes(requests_i_j_k_l, Market_participant)
requests_i_j_k = requests_i_j_k_l(i, j, k, 1) + ... + requests_i_j_k_l(i, j, k, L)
requests_i_j_k = requests_i_j_k(1),             ...,  requests_i_j_k(N)
    where
        requests_i_j_k_l(i, j, k, l) of  number # Запрашиваемый объем НП
        requests_i_j_k(i, j, k)      of  number
        requests_i_j_k_l of matrix(Product, Refinery, Region, Market_participant)
        requests_i_j_k   of matrix(Product, Refinery, Region)
        requests_i_j_k_l(i, j, k, 1), ..., requests_i_j_k_l(i, j, k, L) => requests_i_j_k_l(l)
        requests_i_j_k(1),            ..., requests_i_j_k(N)            => requests_i_j_k(i)
            where
                requests_i_j_k_l(l) of matrix(Product, Refinery, Region)
                requests_i_j_k(i)   of matrix(         Refinery, Region)
                    where
                        Product, Refinery, Region, Market_participant from axis # Оси заявок
                        i  of I  from index # Индексы нефпродукта
                        j  of J  from index # Индексы НПЗ
                        k  of K  from index # Индексы региона
                        l  of P  from index # Индексы субъекта рынка
                        L from index # Количество субъектов рынка
                        N from index # Количество нефпродуктов

requests_i_j(i) = (
    (i, j) = requests_i_j_k(i, j, 1) + ... + requests_i_j_k(i, j, Q)
)
    where
        requests_i_j_k(i, j, k) of  number
        requests_i_j(i, j)     of   number
        requests_i_j_k  of matrix(Product, Refinery, Region)
        requests_i_j    of matrix(Product, Refinery, Region)
        requests_i_j(i) of matrix(         Refinery, Region)
        requests_i_j_k(i, j, 1), ..., requests_i_j_k(i, j, Q) => requests_i_j_k(k)
            where
                Product, Refinery, Region from axis # Оси
                i  of I  from index # Индексы нефпродукта
                j  of J  from index # Индексы НПЗ
                s  of C  from index # Индексы условий поставки
                k  of K  from index # Индексы региона
                Q from index # Количество регионов

# Матрица объемов в запросах от всех субъектов ранка, размерами N x M
requests_i_j = sum_by_axes(requests_i_j_k_l, Ship_terms, Region, Market_participant)
requests_i_j = sum_by_axes(requests_i_j_k,   Ship_terms, Region)
requests_i_j = sum_by_axes(requests_i_j_s,   Ship_terms)
requests_i_j = requests_i_j_k(i, j, 1) + ... + requests_i_j_k(i, j, Q)
requests_i_j = requests_i_j(1),          ...,  requests_i_j(I)
    where
        requests_i_j_k_l(i, k, j, l) of  number # Запрашиваемый объем НП
        requests_i_j_k(i, k, j, l)   of  number
        requests_i_j(i, j)           of  number
        requests_i_j_k_l of matrix(Product, Refinery, Region, Market_participant)
        requests_i_j_k   of matrix(Product, Refinery, Region)
        requests_i_j     of matrix(Product, Refinery)
        requests_i_j_k(i, j, 1),  ..., requests_i_j_k(i, j, Q)  => requests_i_j_k(k)
        requests_i_j(1),          ..., requests_i_j(I)          => requests_i_j(i)
            where
                Product, Region, Ship_terms, Refinery, Market_participant from axis # Оси агрегатов
                i  of I  from index # Индексы нефпродукта
                k  of K from index # Индексы региона
                s  of C  from index # Индексы условий поставки
                j  of J  from index # Индексы НПЗ
                l  of P  from index # Индексы субъекта рынка
                Q from index # Количество регионов
                I from index # Количество нефпродуктов
