                                i  of I  from index # Индексы нефпродукта
                                j  of J  from index # Индексы НПЗ
                                k  of k  from index # Индексы региона
                                l  of P  from index # Индексы субъекта рынка
                                l0 of R  from index # Индексы очереди
                                s  of C  from index # Индексы условий поставки

# Заявки субъектов рынка за рассматриваемый период обслуживаемые в первую очередь
requests_i_j_k_l_s_first = filter_by_coordinate(requests_i_j_k_l_s_l0, First)
    where
        requests_i_j_k_l_s_l0(i, j, k, l, l0, s) of  number # Запрашиваемый объем НП
        requests_i_j_k_l_s_first(i, j, k, l, s)  of  number
        requests_i_j_k_l_s_l0    of matrix(Product, Refinery, Region, Market_participant, Queue, Ship_terms)
        requests_i_j_k_l_s_first of matrix(Product, Refinery, Region, Market_participant, Ship_terms)
            where
                First from Queue
                    where
                        Product, Refinery, Region, Market_participant, Queue, Ship_terms from axis # Оси заявок
                        i  of I  from index # Индексы нефпродукта
                        j  of J  from index # Индексы НПЗ
                        k  of k  from index # Индексы региона
                        l  of P  from index # Индексы субъекта рынка
                        l0 of R  from index # Индексы очереди
                        s  of C  from index # Индексы условий поставки

requests_i_j_k_l_l0(i) = (
    (i, j) = (
        (i, j, k) = (
            (i, j, k, l) = (
