coordinate = coordinate from matrix_types.lang
axis       = axis       from matrix_types.lang
matrix     = matrix     from matrix_types.lang
condition  = condition  from matrix_types.lang

# Операции с матрицами

## Служебные операции

### - Создать пустую матрицу по координатам ✅

new_empty(...Tcoords) = new_empty_matrix
    where
        new_empty_matrix: matrix(...Tcoords) # Пустая матрица по заданным осям
        ...Tcoords = c.1, ..., c.n: coordinate # Список координат

### - Создать без оси
new_empty_without_axis(matrix_source, axis_to_remove) = new_empty_matrix_without_axis
    where
        matrix_source: matrix(axis_to_remove, ...Taxis) # Исходная матрица с удаляемой осью
        axis_to_remove: axis # Удаляемая ось
        new_empty_matrix_without_axis: matrix(...Taxis) # Результат без удаляемой оси
            where
                ...Taxis = a.1, ..., a.n: axis # Оставшиеся оси

### - Копировать значения матрицы
copy_values(matrix_source, copied_matrix) = copied_matrix*
    where
        matrix_source: matrix # Источник значений
        copied_matrix: matrix # Приёмник (форма/координаты)
        copied_matrix*: matrix # Результат копирования значений

