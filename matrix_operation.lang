### - Для каждого элемента

for_each_element(matrix_source, operat, value) = scaled_matrix
    where
        matrix_source: matrix # Исходная матрица
        operat: operation # Операция для применения к каждому элементу
        value: number # Параметр операции
        scaled_matrix: matrix # Результирующая матрица

### - Фильтровать по значению

filter_by_value(matrix_source, condit, value) = filtered_matrix_by_value
    where
        matrix_source: matrix # Исходная матрица
        condit: Condition # Условие сравнения (например, <, >=)
        value: number # Порог/значение сравнения
        filtered_matrix_by_value: matrix # Результат фильтрации

### - Фильтровать по матрице

filter_by_pair(matrix_source, condit, matrix_condition) = filtered_matrix_by_pair
    where
        matrix_source: matrix # Первая матрица
        condit: condition # Условие сравнения
        matrix_condition: matrix # Вторая матрица (сопоставляемая)
        filtered_matrix_by_pair: matrix # Результат фильтрации

### - Для каждой пары

for_each_pair(matrix_source_1, operat, matrix_source_2) = matrix_result
    where
        matrix_source_1: matrix(...Taxis) # Левая матрица
        matrix_source_2: matrix # Правая матрица
        operat: operation # Операция поэлементно
        matrix_result: matrix(...Taxis) # Результат
            where
                ...Taxis: a.1, ..., a.n # Общие оси результата
                    where
                        a.1: axis # Ось
                        ...
                        a.n: axis # Ось

### - Количество координат по оси

count_coordinates_by_axis(matrix_source, axis) = counted_matrix
    where
        matrix_source: matrix # Исходная матрица
        axis: axis # Ось, по которой считаем количество координат
        counted_matrix: matrix # Результирующая матрица численностей

### - Фильтровать по координате

filter_by_coordinate(matrix_source, coordinate) = filtered_matrix_by_coordinate
    where
        matrix_source: matrix # Исходная матрица
        coordinate: coordinate # Фиксируемая координата
        filtered_matrix_by_coordinate: matrix # Результат фильтрации по координате
